#!/bin/bash
# Post-install: register and start the LaunchDaemon
LAUNCH_DAEMON="/Library/LaunchDaemons/com.claudepipeline.daemon.plist"

cat > "$LAUNCH_DAEMON" << 'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claudepipeline.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/claude-daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>UserName</key>
    <string>root</string>
    <key>StandardErrorPath</key>
    <string>/var/mobile/claude-daemon/stderr.log</string>
    <key>StandardOutPath</key>
    <string>/var/mobile/claude-daemon/stdout.log</string>
</dict>
</plist>
PLIST

chmod 644 "$LAUNCH_DAEMON"
launchctl load "$LAUNCH_DAEMON" 2>/dev/null || true
echo "claude-daemon installed and started"
